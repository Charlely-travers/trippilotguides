---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Button from "@/components/Button.astro";
import Card from "@/components/Card.astro";
import { DISCLAIMER, SITE } from "@/consts";
import { guides as legacyGuides } from "@/data/guides";
import { getCityImage } from "@/data/cities";
import { AlertTriangle } from "lucide-astro";
import { resolveBlogCtas } from "@/lib/destination-ctas.mjs";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);

const publishedGuideEntries = (await getCollection("guides"))
  .filter((entry) => !entry.data.draft)
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    price: entry.data.price,
  }));

const publishedChecklistEntries = (await getCollection("checklists"))
  .filter((entry) => !entry.data.draft)
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
  }));

const ctas = resolveBlogCtas({
  postId: post.id,
  postData: post.data,
  publishedGuides: publishedGuideEntries,
  publishedChecklists: publishedChecklistEntries,
  legacyGuides,
  legacyChecklistHref: "/checklists",
});

const dateLabel = post.data.pubDate.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  inLanguage: "fr-FR",
  author: { "@type": "Organization", name: SITE.name },
  publisher: { "@type": "Organization", name: SITE.name },
  mainEntityOfPage: new URL(`/blog/${post.id}`, SITE.url).href,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Blog", item: new URL("/blog", SITE.url).href },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: new URL(`/blog/${post.id}`, SITE.url).href,
    },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <article>
    <header class="relative overflow-hidden">
      <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
      <Container class="py-12 sm:py-16">
        <nav class="mx-auto max-w-3xl text-sm text-ink-500" aria-label="Fil d'Ariane">
          <a href="/" class="hover:text-brand-700">Accueil</a>
          <span class="mx-1.5" aria-hidden="true">/</span>
          <a href="/blog" class="hover:text-brand-700">Blog</a>
        </nav>
        <div class="mx-auto mt-4 max-w-3xl">
          <div class="flex flex-wrap items-center gap-3">
            <Badge variant="neutral">{post.data.readingTime} de lecture</Badge>
            <span class="text-sm text-ink-500">{dateLabel}</span>
          </div>
          <h1
            class="mt-4 font-display text-3xl font-extrabold leading-[1.15] tracking-tight text-ink-900 sm:text-4xl"
          >
            {post.data.title}
          </h1>
          <p class="mt-4 text-lg text-ink-700">{post.data.description}</p>
        </div>
      </Container>
    </header>

    <Container class="pb-8">
      <div class="mx-auto max-w-3xl">
        <div
          class="mb-10 flex flex-col gap-3 rounded-2xl border border-brand-100 bg-brand-50 p-5 sm:flex-row sm:items-center sm:justify-between"
        >
          <p class="text-sm font-medium text-ink-900">
            Prépare ton voyage à {ctas.destination} avec le bon contenu, au bon moment.
          </p>
          <Button href={ctas.top.href} external={ctas.top.external} variant="primary">
            {ctas.top.label}
          </Button>
        </div>

        <div class="prose-article">
          <Content />
        </div>

        <p
          class="mt-10 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800"
          role="note"
        >
          <AlertTriangle class="mr-1 inline h-4 w-4 text-amber-600" />
          {DISCLAIMER}
        </p>

        <Card class="mt-10 overflow-hidden">
          <div class="grid items-stretch gap-0 sm:grid-cols-[1fr_1.4fr]">
            <div
              class="relative min-h-44 overflow-hidden"
              aria-hidden="true"
            >
              <img
                src={getCityImage(post.id).card}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-transparent to-black/10"></div>
            </div>
            <div class="p-7">
              <Badge variant={ctas.guide.available ? "success" : "soft"}>
                {ctas.guide.available ? "Guide complet" : "Produit en préparation"}
              </Badge>
              <h2 class="mt-3 font-display text-xl font-bold text-ink-900">
                {ctas.guide.title}
              </h2>
              <p class="mt-2 text-sm text-ink-700">
                {
                  ctas.guide.available
                    ? "Itinéraire jour par jour, budget détaillé et checklist imprimable."
                    : `Le produit payant pour ${ctas.destination} n'est pas encore public. En attendant, explore les guides déjà disponibles.`
                }
              </p>
              <div class="mt-5 flex flex-wrap items-center gap-3">
                <Button href={ctas.guide.href} variant="primary">
                  {ctas.guide.label}
                </Button>
                {ctas.guide.price && (
                  <span class="font-display font-bold text-ink-900">{ctas.guide.price}</span>
                )}
              </div>
            </div>
          </div>
        </Card>
      </div>
    </Container>
  </article>
</BaseLayout>
