---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Button from "@/components/Button.astro";
import Card from "@/components/Card.astro";
import { LINKS, DISCLAIMER } from "@/consts";
import { getGuide } from "@/data/guides";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const guide = getGuide("rome-5-jours-budget-700")!;

const dateLabel = post.data.pubDate.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
>
  <article>
    <!-- En-tête article -->
    <header class="relative overflow-hidden">
      <div
        class={`pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b ${post.data.gradient} opacity-10`}
        aria-hidden="true"
      >
      </div>
      <Container class="py-12 sm:py-16">
        <div class="mx-auto max-w-3xl">
          <a
            href="/blog"
            class="text-sm font-semibold text-brand-700 hover:underline"
            >← Retour au blog</a
          >
          <div class="mt-4 flex flex-wrap items-center gap-3">
            <Badge variant="neutral">{post.data.readingTime} de lecture</Badge>
            <span class="text-sm text-ink-500">{dateLabel}</span>
          </div>
          <h1
            class="mt-4 text-3xl font-extrabold leading-tight text-ink-900 sm:text-4xl"
          >
            {post.data.title}
          </h1>
          <p class="mt-4 text-lg text-ink-700">{post.data.description}</p>
        </div>
      </Container>
    </header>

    <Container class="pb-8">
      <div class="mx-auto max-w-3xl">
        <!-- CTA checklist en haut -->
        <div
          class="mb-10 flex flex-col gap-3 rounded-2xl bg-brand-50 p-5 sm:flex-row sm:items-center sm:justify-between"
        >
          <p class="text-sm font-medium text-ink-900">
            🎁 Reçois la checklist gratuite avant de partir à Rome.
          </p>
          <Button href={LINKS.freeChecklist} external variant="primary">
            Télécharger la checklist
          </Button>
        </div>

        <!-- Contenu Markdown -->
        <div class="prose-article">
          <Content />
        </div>

        <!-- Disclaimer -->
        <p
          class="mt-10 rounded-xl bg-amber-50 px-4 py-3 text-sm text-amber-800 ring-1 ring-amber-200"
          role="note"
        >
          ⚠️ {DISCLAIMER}
        </p>

        <!-- CTA guide complet -->
        <Card class="mt-10 overflow-hidden">
          <div class="grid items-stretch gap-0 sm:grid-cols-[1fr_1.4fr]">
            <div
              class={`relative flex min-h-40 items-center justify-center bg-gradient-to-br ${guide.gradient} p-8`}
              aria-hidden="true"
            >
              <span class="text-6xl drop-shadow">{guide.emoji}</span>
            </div>
            <div class="p-7">
              <Badge variant="success">Guide complet</Badge>
              <h2 class="mt-3 text-xl font-bold text-ink-900">
                {guide.title}
              </h2>
              <p class="mt-2 text-sm text-ink-700">{guide.excerpt}</p>
              <div class="mt-5 flex flex-wrap items-center gap-3">
                <Button href={`/guides/${guide.slug}`} variant="primary">
                  Voir le guide
                </Button>
                <span class="font-bold text-ink-900">{guide.price}</span>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </Container>
  </article>
</BaseLayout>
