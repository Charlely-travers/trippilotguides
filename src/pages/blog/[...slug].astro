---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Button from "@/components/Button.astro";
import Card from "@/components/Card.astro";
import { DISCLAIMER, SITE } from "@/consts";
import { guides as legacyGuides } from "@/data/guides";
import { getCityImage } from "@/data/cities";
import { AlertTriangle, Clock, Calendar, MapPin } from "lucide-astro";
import { resolveBlogCtas } from "@/lib/destination-ctas.mjs";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const city = getCityImage(post.data.destination || post.id);
const heroSrc = post.data.image || city.hero;
const cardSrc = post.data.cardImage || post.data.image || city.card;

const publishedGuideEntries = (await getCollection("guides"))
  .filter((entry) => !entry.data.draft)
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    price: entry.data.price,
  }));

const publishedChecklistEntries = (await getCollection("checklists"))
  .filter((entry) => !entry.data.draft)
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
  }));

const ctas = resolveBlogCtas({
  postId: post.id,
  postData: post.data,
  publishedGuides: publishedGuideEntries,
  publishedChecklists: publishedChecklistEntries,
  legacyGuides,
  legacyChecklistHref: "/checklists",
});

const dateLabel = post.data.pubDate.toLocaleDateString("fr-FR", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  inLanguage: "fr-FR",
  author: { "@type": "Organization", name: SITE.name },
  publisher: { "@type": "Organization", name: SITE.name },
  mainEntityOfPage: new URL(`/blog/${post.id}`, SITE.url).href,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Blog", item: new URL("/blog", SITE.url).href },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: new URL(`/blog/${post.id}`, SITE.url).href,
    },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  jsonLd={[articleSchema, breadcrumbSchema]}
>
  <article>
    {/* HERO IMAGE pleine largeur — contenu ancré en bas, hauteur flexible */}
    <header
      class="relative isolate flex min-h-[24rem] flex-col justify-end overflow-hidden sm:min-h-[28rem] lg:min-h-[32rem]"
    >
      <img
        src={heroSrc}
        alt={`${post.data.destination || ""} — photo de couverture`}
        class="absolute inset-0 -z-10 h-full w-full object-cover"
        loading="eager"
      />
      <div
        class="absolute inset-0 -z-10 bg-gradient-to-t from-black/80 via-black/45 to-black/15"
        aria-hidden="true"
      ></div>
      <Container class="pb-10 pt-32">
        <div class="mx-auto max-w-3xl">
          <nav class="text-sm text-white/80" aria-label="Fil d'Ariane">
            <a href="/" class="hover:text-white">Accueil</a>
            <span class="mx-1.5" aria-hidden="true">/</span>
            <a href="/blog" class="hover:text-white">Blog</a>
          </nav>
          <div class="mt-4 flex flex-wrap items-center gap-2.5">
            {post.data.destination && (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-600/90 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                <MapPin class="h-3.5 w-3.5" />
                {post.data.destination}
              </span>
            )}
            <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
              <Clock class="h-3.5 w-3.5" />
              {post.data.readingTime}
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
              <Calendar class="h-3.5 w-3.5" />
              {dateLabel}
            </span>
          </div>
          <h1
            class="mt-4 font-display text-2xl font-extrabold leading-[1.2] tracking-tight text-white drop-shadow-lg sm:text-4xl lg:text-[2.75rem]"
          >
            {post.data.title}
          </h1>
        </div>
      </Container>
    </header>

    <Container class="py-10">
      <div class="mx-auto max-w-3xl">
        {/* Description + CTA compact */}
        <div class="mb-10 rounded-2xl border border-brand-100 bg-gradient-to-r from-brand-50 to-white p-6">
          <p class="text-ink-700">{post.data.description}</p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-sm font-medium text-ink-900">
              Prépare ton voyage à {ctas.destination} avec le bon contenu.
            </p>
            <Button href={ctas.top.href} external={ctas.top.external} variant="primary">
              {ctas.top.label}
            </Button>
          </div>
        </div>

        {/* Contenu article */}
        <div class="prose-article">
          <Content />
        </div>

        <p
          class="mt-10 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800"
          role="note"
        >
          <AlertTriangle class="mr-1 inline h-4 w-4 text-amber-600" />
          {DISCLAIMER}
        </p>

        {/* CTA Guide complet — redesigné */}
        <Card class="mt-12 overflow-hidden">
          <div class="grid items-stretch gap-0 sm:grid-cols-[1fr_1.6fr]">
            <div class="relative min-h-52 overflow-hidden">
              <img
                src={cardSrc}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent"></div>
            </div>
            <div class="p-7 sm:p-8">
              <Badge variant={ctas.guide.available ? "success" : "soft"}>
                {ctas.guide.available ? "Guide PDF complet" : "Bientôt disponible"}
              </Badge>
              <h2 class="mt-3 font-display text-xl font-bold text-ink-900 sm:text-2xl">
                {ctas.guide.title}
              </h2>
              <p class="mt-2 text-sm text-ink-700">
                {
                  ctas.guide.available
                    ? "Itinéraire jour par jour, budget détaillé, quartiers, transports et checklist imprimable. Tout dans un PDF clair et prêt à suivre."
                    : `Le guide pour ${ctas.destination} est en cours de finalisation. En attendant, explore les guides déjà disponibles.`
                }
              </p>
              <div class="mt-5 flex flex-wrap items-center gap-3">
                <Button href={ctas.guide.href} variant="primary">
                  {ctas.guide.label}
                </Button>
                {ctas.guide.price && (
                  <span class="font-display text-lg font-bold text-ink-900">{ctas.guide.price}</span>
                )}
              </div>
            </div>
          </div>
        </Card>
      </div>
    </Container>
  </article>
</BaseLayout>
