---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Button from "@/components/Button.astro";
import { DISCLAIMER } from "@/consts";
import { getCityImage } from "@/data/cities";
import { AlertTriangle } from "lucide-astro";

export const getStaticPaths = (async () => {
  const entries = await getCollection("checklists");
  return entries
    .filter((e) => !e.data.draft)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, destination, gradient, formLink, guideSlug } = entry.data;
const city = getCityImage(destination.toLowerCase());
const heroSrc = entry.data.image || city.hero;
const isInternalForm = formLink.startsWith("/api/");
// Pour le lead-magnet interne : action propre + slug en champ caché (robuste)
const formAction = isInternalForm ? "/api/lead-magnet" : formLink;
---

<BaseLayout title={title} description={description}>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
    <Container class="py-16 sm:py-24">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <Badge variant="success">100 % gratuit · PDF</Badge>
          <h1 class="mt-4 font-display text-3xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">
            {title}
          </h1>
          <p class="mt-5 text-lg text-ink-700">{description}</p>
          <form
            id="lead-form"
            class="mt-7 flex flex-col gap-3 sm:flex-row"
            action={formAction}
            method={isInternalForm ? "post" : "get"}
            target={isInternalForm ? undefined : "_blank"}
            data-astro-reload
          >
            <input type="hidden" name="slug" value={entry.id} />
            <label for="email" class="sr-only">Votre adresse email</label>
            <input id="email" name="email" type="email" autocomplete="email" required placeholder="ton@email.com" class="w-full rounded-full border border-slate-200 bg-surface px-5 py-3.5 text-ink-900 placeholder:text-ink-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-200 sm:max-w-xs" />
            <Button type="submit" size="lg" variant="primary" class="shrink-0">Recevoir la checklist</Button>
          </form>
          <p id="lead-hint" class="mt-3 text-sm text-ink-500">Pas de spam. Désinscription en un clic.</p>

          {/* Message de confirmation (affiché après envoi) */}
          <div
            id="lead-success"
            hidden
            class="mt-7 flex items-start gap-4 rounded-2xl border border-emerald-200 bg-gradient-to-br from-emerald-50 to-white p-5 shadow-soft"
          >
            <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
              <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 13a8 8 0 0 1 7-7.94"/><path d="M22 6 12 13 9 10"/><path d="M22 6v6a8 8 0 0 1-15.5 2.8"/></svg>
            </span>
            <div>
              <p class="font-display text-base font-bold text-ink-900">C'est envoyé ! Vérifie ta boîte mail</p>
              <p class="mt-1 text-sm text-ink-700">
                Ta checklist arrive dans quelques secondes (pense à regarder les courriers indésirables).
                En attendant, découvre le <a href={`/guides/${guideSlug || entry.id}`} class="font-semibold text-brand-700 hover:underline">guide complet</a>.
              </p>
            </div>
          </div>
        </div>
        <div class="relative aspect-[4/3] overflow-hidden rounded-[1.75rem] shadow-glow">
          <img
            src={heroSrc}
            alt={`Vue de ${destination}`}
            class="h-full w-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-12 sm:py-16">
    <Container class="mx-auto max-w-3xl">
      <div class="prose-article">
        <Content />
      </div>
      {guideSlug && (
        <div class="mt-8 rounded-2xl border border-brand-100 bg-brand-50 p-5 text-center">
          <p class="text-sm font-medium text-ink-900">Pour un itinéraire complet et un budget détaillé :</p>
          <Button href={`/guides/${guideSlug}`} variant="primary" class="mt-3">Voir le guide complet</Button>
        </div>
      )}
      <p class="mx-auto mt-6 max-w-2xl rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-center text-sm text-amber-800" role="note">
        <AlertTriangle class="mr-1 inline h-4 w-4 text-amber-600" />
        {DISCLAIMER}
      </p>
    </Container>
  </section>

  <script>
    // Soumission AJAX du formulaire checklist avec retour utilisateur inline.
    // Repli : sans JS, le formulaire poste normalement (redirection serveur).
    const form = document.getElementById("lead-form");
    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]');
        const success = document.getElementById("lead-success");
        const hint = document.getElementById("lead-hint");
        const original = btn ? btn.innerHTML : "";
        if (btn) {
          btn.disabled = true;
          btn.innerHTML = "Envoi…";
        }
        try {
          // IMPORTANT : envoyer en urlencoded (l'API ne parse pas le multipart).
          const params = new URLSearchParams();
          new FormData(form).forEach((value, key) => params.append(key, String(value)));
          const res = await fetch(form.action, {
            method: "POST",
            headers: {
              Accept: "application/json",
              "Content-Type": "application/x-www-form-urlencoded",
            },
            body: params.toString(),
          });
          if (!res.ok) throw new Error("send_failed");
          form.hidden = true;
          if (hint) hint.hidden = true;
          if (success) success.hidden = false;
        } catch (err) {
          if (btn) {
            btn.disabled = false;
            btn.innerHTML = original;
          }
          if (hint) {
            hint.textContent = "Oups, une erreur est survenue. Réessaie dans un instant.";
            hint.classList.add("text-red-600");
          }
        }
      });
    }
  </script>
</BaseLayout>
