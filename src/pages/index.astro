---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Button from "@/components/Button.astro";
import Badge from "@/components/Badge.astro";
import Card from "@/components/Card.astro";
import BlogCard from "@/components/BlogCard.astro";
import CTASection from "@/components/CTASection.astro";
import { featuredGuide } from "@/data/guides";
import { getCityImage } from "@/data/cities";
import { LINKS, SITE } from "@/consts";

const featuredCity = getCityImage(featuredGuide.slug);

const steps = [
  {
    n: "1",
    title: "Choisissez votre destination",
    text: "Sélectionnez le guide qui correspond à votre voyage et à la durée de votre séjour.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    n: "2",
    title: "Téléchargez le guide PDF",
    text: "Recevez immédiatement un PDF complet, clair et imprimable, prêt à l'emploi.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`,
  },
  {
    n: "3",
    title: "Partez avec un planning clair",
    text: "Suivez l'itinéraire jour par jour, sans stress et sans perdre de temps sur place.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
  },
];

const reasons = [
  { title: "Budget détaillé", text: "Hébergement, repas, transports et visites : un budget réaliste poste par poste." },
  { title: "Itinéraire jour par jour", text: "Matin, après-midi et soir organisés pour profiter sans courir." },
  { title: "Conseils logement", text: "Les meilleurs quartiers où dormir selon votre budget et votre style." },
  { title: "Checklist avant départ", text: "Documents, valise, applis : vous ne risquez plus rien d'oublier." },
  { title: "Format imprimable", text: "Un PDF propre à garder sur votre téléphone ou à imprimer." },
  { title: "Pensé pour les premiers voyages", text: "Des explications simples, idéales pour une première visite." },
];

const stats = [
  { value: "5 jours", label: "d'itinéraire détaillé" },
  { value: "≈ 700€", label: "budget tout compris" },
  { value: "PDF", label: "imprimable & hors-ligne" },
];

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={SITE.defaultTitle} description={SITE.defaultDescription}>
  {/* HERO */}
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
    <Container class="py-20 sm:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <Badge variant="soft" class="shadow-soft">Guides de voyage digitaux premium</Badge>
        <h1
          class="mt-6 font-display text-4xl font-extrabold leading-[1.08] tracking-tight text-ink-900 sm:text-6xl"
        >
          Des itinéraires de voyage<br class="hidden sm:block" />
          <span class="text-gradient">prêts à suivre</span>, sans stress
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-700 sm:text-xl">
          Guides PDF complets avec planning jour par jour, budget, quartiers où
          dormir, transports, checklist et conseils pratiques.
        </p>
        <div
          class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <Button href={LINKS.freeChecklist} size="lg" variant="primary">
            Télécharger la checklist gratuite
          </Button>
          <Button href="/guides" size="lg" variant="secondary">
            Voir les guides
          </Button>
        </div>
        <p class="mt-4 text-sm text-ink-500">
          PDF instantané · Imprimable · Sans abonnement
        </p>

        <dl
          class="mx-auto mt-12 grid max-w-2xl grid-cols-3 gap-4 rounded-2xl border border-slate-200/80 bg-white/70 p-5 shadow-card backdrop-blur"
        >
          {
            stats.map((stat) => (
              <div class="text-center">
                <dt class="sr-only">{stat.label}</dt>
                <dd>
                  <span class="block font-display text-xl font-extrabold text-ink-900 sm:text-2xl">
                    {stat.value}
                  </span>
                  <span class="mt-1 block text-xs text-ink-500">{stat.label}</span>
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </Container>
  </section>

  {/* COMMENT ÇA MARCHE */}
  <section class="py-12 sm:py-16" aria-labelledby="how-title">
    <Container>
      <div class="max-w-2xl">
        <p class="eyebrow">Comment ça marche</p>
        <h2 id="how-title" class="mt-2 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
          Trois étapes pour un voyage organisé
        </h2>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {
          steps.map((step) => (
            <Card class="p-6" hover>
              <div class="flex items-center gap-3">
                <span
                  class="flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 text-brand-600"
                  set:html={step.icon}
                />
                <span class="eyebrow">Étape {step.n}</span>
              </div>
              <h3 class="mt-4 font-display text-lg font-bold text-ink-900">{step.title}</h3>
              <p class="mt-2 text-ink-700">{step.text}</p>
            </Card>
          ))
        }
      </div>
    </Container>
  </section>

  {/* POURQUOI NOS GUIDES */}
  <section class="py-12 sm:py-16" aria-labelledby="why-title">
    <Container>
      <div class="max-w-2xl">
        <p class="eyebrow">Pourquoi nos guides</p>
        <h2 id="why-title" class="mt-2 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
          Tout ce qu'il faut pour partir l'esprit léger
        </h2>
      </div>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          reasons.map((reason) => (
            <Card class="p-6" hover>
              <div class="h-2 w-10 rounded-full bg-gradient-to-r from-brand-500 to-accent-500"></div>
              <h3 class="mt-3 font-display text-base font-bold text-ink-900">
                {reason.title}
              </h3>
              <p class="mt-1.5 text-sm text-ink-700">{reason.text}</p>
            </Card>
          ))
        }
      </div>
    </Container>
  </section>

  {/* GUIDE ROME MIS EN AVANT */}
  <section class="py-12 sm:py-16" aria-labelledby="featured-title">
    <Container>
      <Card class="overflow-hidden">
        <div class="grid items-stretch gap-0 md:grid-cols-2">
          <div
            class="relative min-h-60 overflow-hidden"
          >
            <img src={featuredCity.hero} alt={`Vue de ${featuredGuide.destination}`} class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
          </div>
          <div class="p-8 sm:p-10">
            <Badge variant="success">● Guide disponible</Badge>
            <h2
              id="featured-title"
              class="mt-4 font-display text-2xl font-bold text-ink-900 sm:text-3xl"
            >
              {featuredGuide.title}
            </h2>
            <p class="mt-3 text-ink-700">{featuredGuide.excerpt}</p>
            <ul class="mt-5 space-y-2 text-sm text-ink-700">
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 text-emerald-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Itinéraire détaillé sur 5 jours
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 text-emerald-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Budget complet pour ≈ 700€
              </li>
              <li class="flex items-center gap-2">
                <svg class="h-4 w-4 text-emerald-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Checklist imprimable incluse
              </li>
            </ul>
            <div class="mt-7 flex flex-wrap items-center gap-3">
              <Button href={`/guides/${featuredGuide.slug}`} size="lg" variant="primary">
                Voir le guide Rome
              </Button>
              <span class="font-display text-lg font-bold text-ink-900">{featuredGuide.price}</span>
            </div>
          </div>
        </div>
      </Card>
    </Container>
  </section>

  {/* ARTICLES RÉCENTS */}
  <section class="py-12 sm:py-16" aria-labelledby="posts-title">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <p class="eyebrow">Le blog</p>
          <h2 id="posts-title" class="mt-2 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
            Articles récents pour préparer ton voyage
          </h2>
        </div>
        <a href="/blog" class="text-sm font-semibold text-brand-700 hover:underline">
          Tous les articles →
        </a>
      </div>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <BlogCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              citySlug={post.data.destination || post.id}
              readingTime={post.data.readingTime}
            />
          ))
        }
      </div>
    </Container>
  </section>

  <CTASection />
</BaseLayout>
