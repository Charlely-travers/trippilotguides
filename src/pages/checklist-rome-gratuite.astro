---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Button from "@/components/Button.astro";
import Card from "@/components/Card.astro";
import { LINKS, DISCLAIMER } from "@/consts";
import { getGuide } from "@/data/guides";

const guide = getGuide("rome-5-jours-budget-700")!;

const checklistItems = [
  { title: "Documents", text: "Passeport/CNI, billets, réservations, assurance.", emoji: "🪪" },
  { title: "Budget", text: "Espèces, carte sans frais, répartition par jour.", emoji: "💶" },
  { title: "Transport", text: "Trajet aéroport, tickets de métro, applis utiles.", emoji: "🚇" },
  { title: "Logement", text: "Adresse, horaires de check-in, contact de l'hôte.", emoji: "🏨" },
  { title: "Valise", text: "Tenues selon la météo, chaussures de marche, chargeurs.", emoji: "🧳" },
  { title: "Applis utiles", text: "Cartes hors-ligne, transports, traduction.", emoji: "📱" },
];
---

<BaseLayout
  title="Checklist gratuite avant de partir à Rome"
  description="Recevez gratuitement une checklist simple pour préparer votre voyage à Rome sans rien oublier : documents, budget, transport, logement et valise."
>
  {/* HERO */}
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
    <Container class="py-16 sm:py-24">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <Badge variant="success">100 % gratuit · PDF</Badge>
          <h1 class="mt-4 font-display text-3xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">
            Checklist gratuite avant de partir à <span class="text-gradient">Rome</span>
          </h1>
          <p class="mt-5 text-lg text-ink-700">
            Recevez une checklist simple pour préparer votre voyage sans rien
            oublier.
          </p>

          <form
            class="mt-7 flex flex-col gap-3 sm:flex-row"
            action="/api/lead-magnet"
            method="post"
            data-astro-reload
          >
            <input type="hidden" name="slug" value="rome-5-jours-budget-700" />
            <label for="email" class="sr-only">Votre adresse email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="ton@email.com"
              class="w-full rounded-full border border-slate-200 bg-surface px-5 py-3.5 text-ink-900 placeholder:text-ink-400 focus:border-brand-400 focus:outline-none focus:ring-2 focus:ring-brand-200 sm:max-w-xs"
            />
            <Button type="submit" size="lg" variant="primary" class="shrink-0">
              Recevoir la checklist
            </Button>
          </form>
          <p class="mt-3 text-sm text-ink-500">
            Pas de spam. Désinscription en un clic.
          </p>
        </div>

        <div
          class="relative flex aspect-[4/3] items-center justify-center overflow-hidden rounded-[1.75rem] bg-gradient-to-br from-emerald-400 via-teal-400 to-cyan-500 shadow-glow"
          aria-hidden="true"
        >
          <div
            class="absolute inset-0 opacity-30 mix-blend-overlay"
            style="background-image: radial-gradient(circle at 25% 15%, rgba(255,255,255,.6), transparent 45%);"
          ></div>
          <span class="text-8xl drop-shadow">📝</span>
        </div>
      </div>
    </Container>
  </section>

  {/* CE QU'IL Y A DANS LA CHECKLIST */}
  <section class="py-12 sm:py-16" aria-labelledby="content-title">
    <Container>
      <div class="max-w-2xl">
        <p class="eyebrow">Ce que tu reçois</p>
        <h2 id="content-title" class="mt-2 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
          Ce qu'il y a dans la checklist
        </h2>
      </div>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          checklistItems.map((item) => (
            <Card class="p-6" hover>
              <span class="text-2xl" aria-hidden="true">
                {item.emoji}
              </span>
              <h3 class="mt-3 font-display text-base font-bold text-ink-900">
                {item.title}
              </h3>
              <p class="mt-1.5 text-sm text-ink-700">{item.text}</p>
            </Card>
          ))
        }
      </div>
    </Container>
  </section>

  {/* PRÉSENTATION DU GUIDE COMPLET */}
  <section class="py-12 sm:py-16">
    <Container>
      <Card class="overflow-hidden">
        <div class="grid items-stretch gap-0 md:grid-cols-2">
          <div class="p-8 sm:p-10">
            <Badge variant="success">Pour aller plus loin</Badge>
            <h2 class="mt-4 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
              Le guide complet Rome en 5 jours
            </h2>
            <p class="mt-3 text-ink-700">
              La checklist t'aide à ne rien oublier. Le guide complet, lui, te
              donne l'itinéraire jour par jour, le budget détaillé, les
              quartiers où dormir et bien plus.
            </p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
              <span class="font-display text-2xl font-extrabold text-ink-900">
                {guide.price}
              </span>
              <Button href={`/guides/${guide.slug}`} size="lg" variant="primary">
                Découvrir le guide
              </Button>
              <a
                href={LINKS.buyRomeGuide}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-semibold text-brand-700 hover:underline"
              >
                Acheter directement
              </a>
            </div>
          </div>
          <div
            class={`relative flex min-h-60 items-center justify-center overflow-hidden bg-gradient-to-br ${guide.gradient} p-10`}
            aria-hidden="true"
          >
            <div
              class="absolute inset-0 opacity-30 mix-blend-overlay"
              style="background-image: radial-gradient(circle at 25% 15%, rgba(255,255,255,.6), transparent 45%);"
            ></div>
            <span class="text-8xl drop-shadow">{guide.emoji}</span>
          </div>
        </div>
      </Card>

      <p
        class="mx-auto mt-6 max-w-2xl rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-center text-sm text-amber-800"
        role="note"
      >
        ⚠️ {DISCLAIMER}
      </p>
    </Container>
  </section>
</BaseLayout>
