---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import { SITE, COMPANY, LINKS, LEGAL_UPDATED } from "@/consts";
---

<BaseLayout
  title="Mentions légales"
  description="Mentions légales du site TripPilot Guides : éditeur, hébergeur et informations légales."
>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
    <Container class="py-14 sm:py-20">
      <div class="mx-auto max-w-3xl">
        <h1 class="font-display text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">
          Mentions légales
        </h1>
        <p class="mt-3 text-sm text-ink-500">Dernière mise à jour : {LEGAL_UPDATED}</p>

        <div class="prose-article mt-8">
          <h2>Éditeur du site</h2>
          <p>
            Le site <strong>{SITE.name}</strong> (accessible à l'adresse
            {SITE.url}) est édité par :
          </p>
          <ul>
            <li><strong>Éditeur :</strong> {COMPANY.legalName}</li>
            <li><strong>Statut :</strong> {COMPANY.status}</li>
            <li><strong>SIRET :</strong> {COMPANY.siret}</li>
            <li><strong>Adresse :</strong> {COMPANY.address}</li>
            <li><strong>Contact :</strong> {LINKS.email}</li>
            <li><strong>Directeur de la publication :</strong> {COMPANY.publicationManager}</li>
          </ul>

          <h2>Hébergement</h2>
          <p>Le site est hébergé par :</p>
          <ul>
            <li><strong>Hébergeur :</strong> {COMPANY.host.name}</li>
            <li><strong>Adresse :</strong> {COMPANY.host.address}</li>
          </ul>

          <h2>Propriété intellectuelle</h2>
          <p>
            L'ensemble des contenus présents sur ce site (textes, guides PDF,
            visuels, logo, structure) est la propriété de l'éditeur, sauf mention
            contraire. Toute reproduction, distribution ou réutilisation, totale
            ou partielle, sans autorisation écrite préalable est interdite.
          </p>
          <p>
            Les guides vendus sur ce site sont des produits numériques destinés
            à un usage personnel. Leur revente ou redistribution est interdite.
          </p>

          <h2>Responsabilité</h2>
          <p>
            Les informations contenues dans les guides et les articles (prix,
            horaires, adresses) sont fournies à titre indicatif et peuvent
            évoluer. {SITE.name} ne peut être tenu responsable d'éventuelles
            erreurs ou d'informations devenues obsolètes. Vérifiez toujours les
            informations importantes (billets, horaires, conditions d'entrée)
            auprès des sources officielles avant votre départ.
          </p>

          <h2>Liens externes</h2>
          <p>
            Ce site peut contenir des liens vers des sites tiers (plateformes de
            vente, formulaires). {SITE.name} n'exerce aucun contrôle sur ces
            sites et décline toute responsabilité quant à leur contenu.
          </p>

          <h2>Contact</h2>
          <p>
            Pour toute question, vous pouvez nous écrire à
            <a href={`mailto:${LINKS.email}`}>{LINKS.email}</a> ou via notre
            <a href="/contact">page de contact</a>.
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
