---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Button from "@/components/Button.astro";
import Card from "@/components/Card.astro";
import { LINKS } from "@/consts";
import { BookOpen, Download, Globe } from "lucide-astro";

const topics = [
  { title: "Question sur un guide", text: "Contenu, format, mise à jour : on répond avec plaisir.", Icon: BookOpen },
  { title: "Problème de téléchargement", text: "Achat effectué mais pas reçu ? Écris-nous, on règle ça.", Icon: Download },
  { title: "Suggestion de destination", text: "Une ville que tu aimerais voir couverte ? Dis-le-nous.", Icon: Globe },
];
---

<BaseLayout
  title="Contact"
  description="Une question sur nos guides de voyage PDF ? Contactez l'équipe TripPilot Guides par email, on vous répond rapidement."
>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
    <Container class="py-16 sm:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <Badge variant="soft" class="shadow-soft">On vous répond</Badge>
        <h1 class="mt-5 font-display text-3xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">
          Une question ? <span class="text-gradient">Parlons-en</span>
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-lg text-ink-700">
          Le moyen le plus simple de nous joindre est l'email. On lit tout et on
          répond généralement sous 48 h ouvrées.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href={`mailto:${LINKS.email}`} size="lg" variant="primary">
            Écrire à {LINKS.email}
          </Button>
          <Button href="/checklists" size="lg" variant="secondary">
            Voir les checklists gratuites
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="pb-16 sm:pb-20">
    <Container>
      <div class="grid gap-5 sm:grid-cols-3">
        {
          topics.map((topic) => (
            <Card class="p-6" hover>
              <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-50 text-brand-600" aria-hidden="true">
                <topic.Icon class="h-5 w-5" />
              </span>
              <h2 class="mt-3 font-display text-base font-bold text-ink-900">{topic.title}</h2>
              <p class="mt-1.5 text-sm text-ink-700">{topic.text}</p>
            </Card>
          ))
        }
      </div>
    </Container>
  </section>
</BaseLayout>
