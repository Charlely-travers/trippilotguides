---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import GuideCard from "@/components/GuideCard.astro";
import CTASection from "@/components/CTASection.astro";
import { mergeGuidesWithCollection } from "@/data/guides";
import { SITE } from "@/consts";

const collectionEntries = await getCollection("guides");
const guides = mergeGuidesWithCollection(collectionEntries);
const available = guides.filter((g) => g.status === "available").length;

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Guides de voyage TripPilot",
  itemListElement: guides.map((g, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: g.title,
    url: new URL(`/guides/${g.slug}`, SITE.url).href,
  })),
};
---

<BaseLayout
  title="Tous les guides de voyage"
  description="Découvrez nos guides de voyage PDF : itinéraires jour par jour, budgets détaillés et conseils pratiques. Rome déjà disponible, d'autres destinations bientôt."
  jsonLd={itemListSchema}
>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
    <Container class="py-16 sm:py-20">
      <div class="max-w-2xl">
        <Badge variant="soft" class="shadow-soft">{available} guide{available > 1 ? "s" : ""} disponible{available > 1 ? "s" : ""} · plus à venir</Badge>
        <h1 class="mt-4 font-display text-3xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">
          Nos guides de voyage
        </h1>
        <p class="mt-4 text-lg text-ink-700">
          Des itinéraires PDF prêts à suivre, pensés pour voyager sereinement.
          Choisis ta destination et pars avec un planning clair.
        </p>
      </div>
    </Container>
  </section>

  <section class="pb-16 sm:pb-20">
    <Container>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {guides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </Container>
  </section>

  <CTASection
    title="Une destination t'intéresse ?"
    text="Récupère la checklist gratuite et sois prévenu dès qu'un nouveau guide sort."
    primaryLabel="Voir les checklists"
    primaryHref="/checklists"
  />
</BaseLayout>
