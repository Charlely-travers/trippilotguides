---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import GuideCard from "@/components/GuideCard.astro";
import CTASection from "@/components/CTASection.astro";
import { guides } from "@/data/guides";

const available = guides.filter((g) => g.status === "available").length;
---

<BaseLayout
  title="Tous les guides de voyage"
  description="Découvrez nos guides de voyage PDF : itinéraires jour par jour, budgets détaillés et conseils pratiques. Rome déjà disponible, d'autres destinations bientôt."
>
  <section class="py-14 sm:py-20">
    <Container>
      <div class="max-w-2xl">
        <Badge variant="brand">{available} guide disponible · plus à venir</Badge>
        <h1 class="mt-4 text-3xl font-extrabold text-ink-900 sm:text-4xl">
          Nos guides de voyage
        </h1>
        <p class="mt-4 text-lg text-ink-700">
          Des itinéraires PDF prêts à suivre, pensés pour voyager sereinement.
          Choisis ta destination et pars avec un planning clair.
        </p>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {guides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </Container>
  </section>

  <CTASection
    title="Une destination t'intéresse ?"
    text="Récupère la checklist gratuite pour Rome et sois prévenu dès qu'un nouveau guide sort."
  />
</BaseLayout>
