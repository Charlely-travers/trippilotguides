---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Badge from "@/components/Badge.astro";
import Button from "@/components/Button.astro";
import Card from "@/components/Card.astro";
import FAQ from "@/components/FAQ.astro";
import { LINKS, DISCLAIMER, SITE } from "@/consts";
import { getGuide } from "@/data/guides";
import { getCityImage } from "@/data/cities";
import {
  CalendarDays,
  Euro,
  Building2,
  TrainFront,
  UtensilsCrossed,
  AlertTriangle,
  CheckSquare,
  Globe,
  Luggage,
  Compass,
  Landmark,
  FileText,
} from "lucide-astro";

const guide = getGuide("rome-5-jours-budget-700")!;
const city = getCityImage(guide.slug);

const includes = [
  { title: "Itinéraire matin / après-midi / soir", text: "Chaque journée découpée en trois temps pour profiter sans courir.", Icon: CalendarDays },
  { title: "Budget détaillé", text: "Hébergement, repas, transports et visites estimés poste par poste.", Icon: Euro },
  { title: "Quartiers recommandés", text: "Où dormir selon ton budget et tes envies, avec les zones à éviter.", Icon: Building2 },
  { title: "Transports", text: "Aéroport, métro, bus et déplacements à pied expliqués simplement.", Icon: TrainFront },
  { title: "Restaurants et pauses", text: "Des adresses et des types de lieux pour bien manger sans se ruiner.", Icon: UtensilsCrossed },
  { title: "Erreurs à éviter", text: "Les pièges classiques d'un premier voyage à Rome.", Icon: AlertTriangle },
  { title: "Checklist imprimable", text: "Une liste claire à cocher avant de partir.", Icon: CheckSquare },
];

const forWho = [
  { title: "Premier voyage à Rome", text: "Tout est expliqué simplement, aucune expérience requise.", Icon: Globe },
  { title: "Couple ou solo", text: "Un itinéraire adaptable que tu voyages à deux ou seul.", Icon: Luggage },
  { title: "Budget maîtrisé", text: "Pensé autour d'un budget réaliste d'environ 700€.", Icon: Euro },
  { title: "Envie d'un planning simple", text: "Tu veux profiter, pas passer des heures à organiser.", Icon: Compass },
];

const previews = [
  { title: "Jour 1 — Centre historique", text: "Colisée, Forum romain et soirée dans le Trastevere.", Icon: Landmark },
  { title: "Budget détaillé", text: "Tableau clair des dépenses jour par jour pour ≈ 700€.", Icon: Euro },
  { title: "Checklist départ", text: "Documents, valise et applis utiles à cocher avant le vol.", Icon: CheckSquare },
];

const faq = [
  {
    question: "Est-ce un produit physique ?",
    answer:
      "Non, c'est un guide 100 % numérique au format PDF. Tu le reçois après ton achat et tu peux le consulter sur ton téléphone, ta tablette ou ton ordinateur, ou l'imprimer.",
  },
  {
    question: "Le guide est-il mis à jour ?",
    answer:
      "Le guide est revu régulièrement. Cela dit, les prix et horaires des lieux peuvent évoluer : vérifie toujours les informations importantes (billets, horaires d'ouverture) avant ton départ.",
  },
  {
    question: "Est-ce adapté pour un premier voyage ?",
    answer:
      "Oui, le guide est justement pensé pour un premier voyage à Rome. Tout est expliqué pas à pas, des transports depuis l'aéroport jusqu'à l'organisation de chaque journée.",
  },
  {
    question: "Puis-je l'imprimer ?",
    answer:
      "Bien sûr. Le PDF est conçu pour rester lisible une fois imprimé, pour l'avoir avec toi sans dépendre de ta batterie ou de ta connexion.",
  },
];

const days = [
  "Centre antique : Colisée & Forum",
  "Vatican & Saint-Pierre",
  "Trastevere & places baroques",
  "Quartiers & musées",
  "Shopping, détente & départ",
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: guide.title,
  description:
    "Guide PDF Rome en 5 jours : itinéraire jour par jour, budget détaillé, quartiers où dormir, transports, restaurants et checklist imprimable.",
  brand: { "@type": "Brand", name: SITE.name },
  offers: {
    "@type": "Offer",
    price: "9",
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock",
    url: new URL(`/guides/${guide.slug}`, SITE.url).href,
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};
---

<BaseLayout
  title="Rome en 5 jours — itinéraire complet avec budget 700€"
  description="Guide PDF Rome en 5 jours : itinéraire jour par jour, budget détaillé 700€, quartiers où dormir, transports, restaurants et checklist imprimable."
  type="article"
  jsonLd={[productSchema, faqSchema]}
>
  {/* HERO PRODUIT */}
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-mesh" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 bg-grid" aria-hidden="true"></div>
    <Container class="py-14 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <Badge variant="success">● Guide disponible · PDF</Badge>
          <h1
            class="mt-4 font-display text-3xl font-extrabold leading-[1.12] tracking-tight text-ink-900 sm:text-5xl"
          >
            Rome en 5 jours — itinéraire complet avec budget <span class="text-gradient">700€</span>
          </h1>
          <p class="mt-5 text-lg text-ink-700">
            Un guide PDF clair et complet pour vivre Rome sans stress :
            planning jour par jour, budget réaliste, logement, transports et
            checklist imprimable.
          </p>

          <div class="mt-7 flex flex-wrap items-center gap-4">
            <span class="font-display text-3xl font-extrabold text-ink-900">{guide.price}</span>
            <Button href="/contact" size="lg" variant="primary">
              Acheter le guide (bientôt)
            </Button>
            <a
              href="/checklists/rome"
              class="text-sm font-semibold text-brand-700 hover:underline"
            >
              ou téléchargez d'abord la checklist gratuite
            </a>
          </div>

          <div class="mt-6 flex flex-wrap gap-2">
            <Badge variant="neutral">5 jours</Badge>
            <Badge variant="neutral">≈ 700€</Badge>
            <Badge variant="neutral">Premier voyage</Badge>
            <Badge variant="neutral">Imprimable</Badge>
          </div>
        </div>

        <div
          class="relative aspect-[4/3] overflow-hidden rounded-[1.75rem] shadow-glow"
        >
          <img
            src={city.hero}
            alt={`Vue de Rome`}
            class="h-full w-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          <span
            class="absolute bottom-5 left-5 rounded-xl bg-white/90 px-4 py-2 text-sm font-bold text-ink-900 backdrop-blur"
          >
            Guide PDF · 5 jours
          </span>
        </div>
      </div>
    </Container>
  </section>

  {/* CE QUE CONTIENT LE GUIDE */}
  <section class="py-12 sm:py-16" aria-labelledby="includes-title">
    <Container>
      <div class="max-w-2xl">
        <p class="eyebrow">Contenu du guide</p>
        <h2 id="includes-title" class="mt-2 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
          Ce que contient le guide
        </h2>
      </div>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          includes.map((item) => (
            <Card class="p-6" hover>
              <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-50 text-brand-600" aria-hidden="true">
                <item.Icon class="h-5 w-5" />
              </span>
              <h3 class="mt-3 font-display text-base font-bold text-ink-900">
                {item.title}
              </h3>
              <p class="mt-1.5 text-sm text-ink-700">{item.text}</p>
            </Card>
          ))
        }
      </div>

      <Card class="mt-8 p-6">
        <h3 class="font-display text-base font-bold text-ink-900">
          Aperçu de l'itinéraire sur 5 jours
        </h3>
        <ol class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
          {
            days.map((day, i) => (
              <li class="rounded-xl border border-brand-100 bg-brand-50 p-4">
                <span class="eyebrow">Jour {i + 1}</span>
                <p class="mt-1 text-sm font-medium text-ink-900">{day}</p>
              </li>
            ))
          }
        </ol>
      </Card>
    </Container>
  </section>

  {/* POUR QUI */}
  <section class="py-12 sm:py-16" aria-labelledby="forwho-title">
    <Container>
      <div class="max-w-2xl">
        <p class="eyebrow">Public cible</p>
        <h2 id="forwho-title" class="mt-2 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
          Pour qui est ce guide ?
        </h2>
      </div>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          forWho.map((item) => (
            <Card class="p-6" hover>
              <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-50 text-brand-600" aria-hidden="true">
                <item.Icon class="h-5 w-5" />
              </span>
              <h3 class="mt-3 font-display text-base font-bold text-ink-900">
                {item.title}
              </h3>
              <p class="mt-1.5 text-sm text-ink-700">{item.text}</p>
            </Card>
          ))
        }
      </div>
    </Container>
  </section>

  {/* APERÇU DU GUIDE (fausses pages) */}
  <section class="py-12 sm:py-16" aria-labelledby="preview-title">
    <Container>
      <div class="max-w-2xl">
        <p class="eyebrow">Aperçu</p>
        <h2 id="preview-title" class="mt-2 font-display text-2xl font-bold text-ink-900 sm:text-3xl">
          Un aperçu de l'intérieur
        </h2>
      </div>
      <div class="mt-8 grid gap-6 sm:grid-cols-3">
        {
          previews.map((page) => (
            <div class="rounded-2xl border border-slate-200/80 bg-surface p-3 shadow-card">
              <div
                class="flex aspect-[3/4] flex-col justify-between rounded-xl bg-gradient-to-br from-slate-50 to-brand-50 p-5"
                aria-hidden="true"
              >
                <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-600">
                  <page.Icon class="h-6 w-6" />
                </span>
                <div>
                  <div class="h-2 w-3/4 rounded bg-slate-300/70" />
                  <div class="mt-2 h-2 w-full rounded bg-slate-200/70" />
                  <div class="mt-2 h-2 w-5/6 rounded bg-slate-200/70" />
                  <div class="mt-2 h-2 w-2/3 rounded bg-slate-200/70" />
                </div>
              </div>
              <div class="px-2 py-3">
                <h3 class="font-display text-sm font-bold text-ink-900">{page.title}</h3>
                <p class="mt-1 text-xs text-ink-500">{page.text}</p>
              </div>
            </div>
          ))
        }
      </div>
      <p class="mt-4 text-xs text-ink-500">
        Aperçu illustratif du type de contenu et de mise en page du guide.
      </p>
    </Container>
  </section>

  {/* FAQ */}
  <section class="py-12 sm:py-16">
    <Container class="max-w-3xl">
      <FAQ items={faq} />
    </Container>
  </section>

  {/* CTA FINAL */}
  <section class="pb-16 sm:pb-20">
    <Container>
      <div class="relative overflow-hidden rounded-[1.75rem] bg-gradient-to-br from-brand-700 via-brand-600 to-accent-600 p-8 text-center shadow-glow sm:p-12">
        <div
          class="pointer-events-none absolute inset-0 opacity-40"
          style="background-image: radial-gradient(26rem 26rem at 15% 0%, rgba(255,255,255,.18), transparent 60%);"
          aria-hidden="true"
        ></div>
        <h2 class="relative font-display text-2xl font-bold text-white sm:text-3xl">
          Prêt à partir à Rome l'esprit léger ?
        </h2>
        <p class="relative mx-auto mt-3 max-w-xl text-brand-50">
          Télécharge le guide PDF et suis un itinéraire clair, jour par jour,
          avec un budget maîtrisé.
        </p>
        <div class="relative mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full bg-white px-7 py-3.5 text-[0.95rem] font-semibold text-brand-700 shadow-soft transition-all hover:-translate-y-0.5 hover:shadow-lift"
          >
            Acheter le guide — {guide.price} (bientôt)
          </a>
          <a
            href="/checklists/rome"
            class="inline-flex items-center justify-center rounded-full px-7 py-3.5 text-[0.95rem] font-semibold text-white ring-1 ring-white/40 transition-all hover:bg-white/10"
          >
            Checklist gratuite
          </a>
        </div>
      </div>

      <p
        class="mx-auto mt-6 max-w-2xl rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-center text-sm text-amber-800"
        role="note"
      >
        <AlertTriangle class="mr-1 inline h-4 w-4 text-amber-600" />
        {DISCLAIMER}
      </p>
    </Container>
  </section>
</BaseLayout>
