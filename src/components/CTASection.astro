---
import Container from "./Container.astro";
import { LINKS } from "@/consts";

interface Props {
  title?: string;
  text?: string;
  primaryLabel?: string;
  primaryHref?: string;
  primaryExternal?: boolean;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const {
  title = "Prêt à préparer votre prochain voyage ?",
  text = "Récupérez la checklist gratuite, puis téléchargez le guide complet pour partir avec un planning clair.",
  primaryLabel = "Télécharger la checklist gratuite",
  primaryHref = LINKS.freeChecklist,
  primaryExternal = false,
  secondaryLabel = "Voir les guides",
  secondaryHref = "/guides",
} = Astro.props;
---

<section class="py-16 sm:py-20">
  <Container>
    <div
      class="relative overflow-hidden rounded-[1.75rem] bg-gradient-to-br from-brand-700 via-brand-600 to-accent-600 px-6 py-14 text-center shadow-glow sm:px-12 sm:py-16"
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-40"
        style="background-image: radial-gradient(28rem 28rem at 15% 0%, rgba(255,255,255,.18), transparent 60%), radial-gradient(24rem 24rem at 90% 100%, rgba(255,255,255,.14), transparent 55%);"
        aria-hidden="true"
      >
      </div>
      <h2 class="relative font-display text-2xl font-bold text-white sm:text-3xl">
        {title}
      </h2>
      <p class="relative mx-auto mt-3 max-w-2xl text-brand-50">{text}</p>
      <div
        class="relative mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
      >
        <a
          href={primaryHref}
          target={primaryExternal ? "_blank" : undefined}
          rel={primaryExternal ? "noopener noreferrer" : undefined}
          class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 text-[0.95rem] font-semibold text-brand-700 shadow-soft transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lift"
        >
          {primaryLabel}
        </a>
        {
          secondaryHref && (
            <a
              href={secondaryHref}
              class="inline-flex items-center justify-center gap-2 rounded-full px-7 py-3.5 text-[0.95rem] font-semibold text-white ring-1 ring-white/40 transition-all duration-200 hover:bg-white/10"
            >
              {secondaryLabel}
            </a>
          )
        }
      </div>
    </div>
  </Container>
</section>
