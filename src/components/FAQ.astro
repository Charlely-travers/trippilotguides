---
interface FaqItem {
  question: string;
  answer: string;
}
interface Props {
  items: FaqItem[];
  title?: string;
}
const { items, title = "Questions fréquentes" } = Astro.props;
---

<section aria-labelledby="faq-title">
  <h2 id="faq-title" class="font-display text-2xl font-bold text-ink-900 sm:text-3xl">
    {title}
  </h2>
  <div class="mt-6 space-y-3">
    {
      items.map((item) => (
        <details class="group rounded-2xl border border-slate-200/80 bg-surface p-5 shadow-soft transition-colors open:border-brand-200">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-ink-900">
            <span>{item.question}</span>
            <span
              class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand-600 transition-transform duration-200 group-open:rotate-45"
              aria-hidden="true"
            >
              +
            </span>
          </summary>
          <p class="mt-3 leading-relaxed text-ink-700">{item.answer}</p>
        </details>
      ))
    }
  </div>
</section>
