---
interface Props {
  class?: string;
  as?: keyof HTMLElementTagNameMap;
  hover?: boolean;
}
const { class: className = "", as = "div", hover = false } = Astro.props;
const Tag = as;
const hoverClasses = hover
  ? "transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lift hover:border-brand-200"
  : "";
---

<Tag
  class={`rounded-2xl border border-slate-200/80 bg-surface shadow-card ${hoverClasses} ${className}`}
>
  <slot />
</Tag>
