---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  external?: boolean;
  class?: string;
  type?: "button" | "submit";
  ariaLabel?: string;
}
const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  class: className = "",
  type = "button",
  ariaLabel,
} = Astro.props;

const base =
  "group relative inline-flex items-center justify-center gap-2 rounded-full font-semibold tracking-tight transition-all duration-200 focus-visible:outline-none disabled:opacity-60";

const sizes: Record<string, string> = {
  md: "px-5 py-2.5 text-sm",
  lg: "px-7 py-3.5 text-[0.95rem]",
};

const variants: Record<string, string> = {
  primary:
    "text-white bg-gradient-to-br from-brand-600 to-accent-600 shadow-soft hover:shadow-lift hover:-translate-y-0.5 ring-1 ring-inset ring-white/10",
  secondary:
    "bg-surface text-ink-900 ring-1 ring-slate-200 shadow-soft hover:ring-brand-400 hover:-translate-y-0.5",
  ghost: "text-brand-700 hover:bg-brand-50",
};

const classes = `${base} ${sizes[size]} ${variants[variant]} ${className}`;
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

{
  href ? (
    <a
      href={href}
      class={classes}
      rel={rel}
      target={target}
      aria-label={ariaLabel}
    >
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}
