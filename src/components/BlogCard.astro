---
import { getCityImage } from "@/data/cities";
import Badge from "./Badge.astro";
import { Clock } from "lucide-astro";

interface Props {
  href: string;
  title: string;
  description: string;
  /** Slug ou nom de ville pour l'image */
  citySlug?: string;
  readingTime: string;
}
const { href, title, description, citySlug = "", readingTime } = Astro.props;
const city = getCityImage(citySlug || href.split("/").pop() || "");
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-surface shadow-card transition-all duration-300 hover:-translate-y-1.5 hover:border-brand-200 hover:shadow-lift"
>
  <a href={href} class="flex flex-1 flex-col">
    <div class="relative h-44 overflow-hidden">
      <img
        src={city.card}
        alt=""
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent"></div>
      <div class="absolute bottom-3 left-4 right-4">
        <h3
          class="font-display text-base font-bold leading-snug text-white drop-shadow-md line-clamp-2 sm:text-lg"
        >
          {title}
        </h3>
      </div>
    </div>
    <div class="flex flex-1 flex-col p-5">
      <div class="flex items-center gap-2 text-xs text-ink-500">
        <Clock class="h-3.5 w-3.5" />
        <span>{readingTime} de lecture</span>
      </div>
      <p class="mt-2 line-clamp-3 text-sm text-ink-600">{description}</p>
      <span
        class="mt-auto inline-flex items-center gap-1 pt-4 text-sm font-semibold text-brand-700"
      >
        Lire l'article
        <span class="transition-transform duration-200 group-hover:translate-x-1"
          >&rarr;</span
        >
      </span>
    </div>
  </a>
</article>
