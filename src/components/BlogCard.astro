---
import Badge from "./Badge.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  emoji: string;
  gradient: string;
  readingTime: string;
}
const { href, title, description, emoji, gradient, readingTime } = Astro.props;
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-surface shadow-card transition-all duration-300 hover:-translate-y-1.5 hover:border-brand-200 hover:shadow-lift"
>
  <a href={href} class="flex flex-1 flex-col">
    <div
      class={`relative flex h-36 items-center justify-center overflow-hidden bg-gradient-to-br ${gradient}`}
      aria-hidden="true"
    >
      <span
        class="text-4xl drop-shadow-sm transition-transform duration-500 group-hover:scale-110"
        >{emoji}</span
      >
    </div>
    <div class="flex flex-1 flex-col p-5">
      <Badge variant="neutral" class="self-start">Article · {readingTime}</Badge>
      <h3
        class="mt-3 font-display text-lg font-bold text-ink-900 transition-colors group-hover:text-brand-700"
      >
        {title}
      </h3>
      <p class="mt-2 line-clamp-3 text-sm text-ink-500">{description}</p>
      <span
        class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700"
      >
        Lire l'article
        <span class="transition-transform duration-200 group-hover:translate-x-1"
          >→</span
        >
      </span>
    </div>
  </a>
</article>
