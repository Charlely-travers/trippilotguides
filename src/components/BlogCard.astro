---
import Badge from "./Badge.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  emoji: string;
  gradient: string;
  readingTime: string;
}
const { href, title, description, emoji, gradient, readingTime } = Astro.props;
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl bg-surface ring-1 ring-slate-200/80 shadow-soft transition-all duration-200 hover:-translate-y-1 hover:shadow-lift"
>
  <a href={href} class="flex flex-1 flex-col">
    <div
      class={`flex h-32 items-center justify-center bg-gradient-to-br ${gradient}`}
      aria-hidden="true"
    >
      <span class="text-4xl drop-shadow-sm">{emoji}</span>
    </div>
    <div class="flex flex-1 flex-col p-5">
      <Badge variant="neutral" class="self-start">Article · {readingTime}</Badge>
      <h3
        class="mt-3 text-lg font-bold text-ink-900 group-hover:text-brand-700"
      >
        {title}
      </h3>
      <p class="mt-2 line-clamp-3 text-sm text-ink-500">{description}</p>
      <span class="mt-4 text-sm font-semibold text-brand-700">
        Lire l'article →
      </span>
    </div>
  </a>
</article>
