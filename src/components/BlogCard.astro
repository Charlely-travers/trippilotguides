---
import { getCityImage } from "@/data/cities";
import Badge from "./Badge.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  /** Slug ou nom de ville pour l'image */
  citySlug?: string;
  readingTime: string;
}
const { href, title, description, citySlug = "", readingTime } = Astro.props;
const city = getCityImage(citySlug || href.split("/").pop() || "");
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-surface shadow-card transition-all duration-300 hover:-translate-y-1.5 hover:border-brand-200 hover:shadow-lift"
>
  <a href={href} class="flex flex-1 flex-col">
    <div class="relative h-36 overflow-hidden">
      <img
        src={city.card}
        alt=""
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
    </div>
    <div class="flex flex-1 flex-col p-5">
      <Badge variant="neutral" class="self-start">Article · {readingTime}</Badge>
      <h3
        class="mt-3 font-display text-lg font-bold text-ink-900 transition-colors group-hover:text-brand-700"
      >
        {title}
      </h3>
      <p class="mt-2 line-clamp-3 text-sm text-ink-500">{description}</p>
      <span
        class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700"
      >
        Lire l'article
        <span class="transition-transform duration-200 group-hover:translate-x-1"
          >&rarr;</span
        >
      </span>
    </div>
  </a>
</article>
