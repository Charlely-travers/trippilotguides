# ---------------------------------------------------------------
# TripPilot Guides — variables d'environnement
# Copiez ce fichier en `.env` (jamais committé) pour un usage local,
# ou configurez-les en "Secrets" du dépôt GitHub pour l'automatisation.
# ---------------------------------------------------------------

# Clé API Mistral (scoring des idées + génération des brouillons)
# https://console.mistral.ai/
MISTRAL_API_KEY=

# Modèle Mistral (optionnel). Ex : mistral-small-latest, mistral-large-latest
MISTRAL_MODEL=mistral-small-latest

# Nombre d'idées (les mieux notées) à transformer en brouillons (optionnel)
GENERATE_COUNT=1

# URL du webhook Discord pour le rapport d'exécution
# Discord > Paramètres du salon > Intégrations > Webhooks
DISCORD_WEBHOOK_URL=
