# ---------------------------------------------------------------
# TripPilot Guides - environment variables
# Copy this file to `.env` for local runs, or configure values as
# GitHub Actions secrets / variables.
# ---------------------------------------------------------------

# Mistral API key for scoring, research and generation.
# https://console.mistral.ai/
MISTRAL_API_KEY=

# Main model for blog/social generation.
MISTRAL_MODEL=mistral-small-latest

# Research model.
MISTRAL_RESEARCH_MODEL=mistral-small-latest

# Guide outline model.
MISTRAL_GUIDE_MODEL=mistral-medium-latest

# Number of ideas to generate per run.
GENERATE_COUNT=1

# Minimum review score required to auto-publish a blog article.
AUTO_PUBLISH_MIN_SCORE=9

# Public site URL used in product metadata and Pinterest pins.
SITE_URL=https://trippilotguides.com

# Optional monetization links.
# If DEFAULT_BUY_LINK is empty and STRIPE_SECRET_KEY is present, the automation
# creates a Stripe Payment Link for each new paid guide.
DEFAULT_BUY_LINK=

# Stripe automatic payment links for generated paid guides.
# Use a test key locally, then a live key in GitHub Secrets when ready.
STRIPE_SECRET_KEY=
AUTO_CREATE_STRIPE_PAYMENT_LINKS=true
STRIPE_PAYMENT_LINK_PRICE_CENTS=900
STRIPE_PAYMENT_LINK_CURRENCY=eur
STRIPE_PAYMENT_LINK_AUTOMATIC_TAX=false
STRIPE_PAYMENT_LINK_ALLOW_PROMO_CODES=false

# Stripe webhook used to email the paid guide after checkout.
# Configure your Stripe dashboard webhook to:
#   https://your-domain.com/api/stripe-webhook
# and listen for checkout.session.completed.
STRIPE_WEBHOOK_SECRET=
GUIDE_DELIVERY_BASE_URL=https://trippilotguides.com/delivery
FULFILLMENT_FROM_EMAIL=TripPilot Guides <hello@trippilotguides.com>

# Free lead-magnet form. If empty, checklist pages remain drafts.
DEFAULT_CHECKLIST_FORM_LINK=

# Optional internal lead magnet instead of Tally/Brevo form.
# Requires a Resend account/API key and a verified sender domain.
INTERNAL_LEAD_MAGNET=false
RESEND_API_KEY=
LEAD_MAGNET_FROM_EMAIL=TripPilot Guides <hello@trippilotguides.com>
LEAD_MAGNET_SUCCESS_URL=

# Pinterest auto-posting. Requires a Pinterest developer app and token with
# boards:read, boards:write, pins:read and pins:write scopes.
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
PINTEREST_MAX_PINS_PER_PRODUCT=3

# Discord webhook for automation reports.
DISCORD_WEBHOOK_URL=
